# Credentials for Playwright E2E tests.
# Copy this file to .env.e2e and fill in real Firebase accounts for each role.
# .env.e2e is gitignored — never commit real credentials.

# Student account (used by game-flow and student-journey tests)
PLAYWRIGHT_TEST_EMAIL=testing@gmail.com
PLAYWRIGHT_TEST_PASSWORD=12345678

# Teacher account (used by teacher-path tests)
PLAYWRIGHT_TEACHER_EMAIL=teacher@example.com
PLAYWRIGHT_TEACHER_PASSWORD=yourpassword

# Admin account (used by admin-path tests)
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=yourpassword