# Credentials for Playwright E2E tests.
# Copy this file to .env.e2e and fill in a real student Firebase account.
# .env.e2e is gitignored — never commit real credentials.
PLAYWRIGHT_TEST_EMAIL=testing@gmail.com
PLAYWRIGHT_TEST_PASSWORD=12345678

PLAYWRIGHT_TEACHER_EMAIL=teacher@example.com
PLAYWRIGHT_TEACHER_PASSWORD=teacherpassword

PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=adminpassword